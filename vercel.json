{
    "version": 2,
    "buildCommand": "cd web && npm install && npm run build",
    "outputDirectory": "web/dist",
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "https://booking-appointment-backend-production.up.railway.app/api/$1"
        },
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ]
}